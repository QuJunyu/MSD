from flask import Flask, render_template, request, redirect, url_for, flash, session

# 初始化Flask应用
app = Flask(__name__)
# 用于session和flash消息的加密密钥(生产环境需更换为复杂密钥)
app.secret_key = 'dev_secret_key_12345'

# 模拟数据库(实际项目中替换为真实数据库)
# 结构: {用户名: 密码}
users_db = {
    "student1": "book123",
    "teacher": "teach456"
}

# 首页路由
@app.route('/')
def home():
    # 如果已登录，显示首页；否则重定向到登录页
    if 'username' in session:
        return f"""
        <h1>Welcome to Campus Second-hand Book Trading Platform</h1>
        <p>Logged in as: {session['username']}</p>
        <a href="/logout">Logout</a>
        """
    return redirect(url_for('login'))

# 登录路由(支持GET和POST方法)
@app.route('/login', methods=['GET', 'POST'])
def login():
    if request.method == 'POST':
        # 获取表单数据
        username = request.form.get('username', '').strip()
        password = request.form.get('password', '').strip()

        # 验证逻辑
        if not username or not password:
            flash('Username and password cannot be empty!')
            return redirect(url_for('login'))
        
        if username in users_db and users_db[username] == password:
            # 登录成功，保存会话
            session['username'] = username
            flash('Login successful!')
            return redirect(url_for('home'))
        else:
            flash('Invalid username or password!')
            return redirect(url_for('login'))
    
    # GET请求：显示登录页面
    return render_template('login.html')

# 注册路由
@app.route('/register', methods=['GET', 'POST'])
def register():
    if request.method == 'POST':
        username = request.form.get('username', '').strip()
        password = request.form.get('password', '').strip()

        if not username or not password:
            flash('Username and password cannot be empty!')
            return redirect(url_for('register'))
        
        if username in users_db:
            flash('Username already exists!')
            return redirect(url_for('register'))
        
        # 注册成功(实际项目中需加密密码后存储)
        users_db[username] = password
        flash('Registration successful! Please login.')
        return redirect(url_for('login'))
    
    # GET请求：显示注册页面
    return render_template('register.html')

# 退出登录路由
@app.route('/logout')
def logout():
    session.pop('username', None)  # 清除会话
    flash('Logged out successfully!')
    return redirect(url_for('login'))

# 启动应用
if __name__ == '__main__':
    app.run(debug=True)  # 开发模式(生产环境需关闭debug)
